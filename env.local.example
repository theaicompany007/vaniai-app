# vaniai-app — copy to .env.local and fill in your values.
# Deployment: set-env-mode.sh (dev|prod) comments DEV block and enables PROD block (or vice versa), then generates .env for the container.
#   Dev:  http://localhost:3100 or https://vaniai.ngrok.app
#   Prod: https://vaniai.theaicompany.co

# ---------------------------------------------------
# Common (always active; not toggled by set-env-mode)
# ---------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

RESEND_API_KEY=

RAZORPAY_DUMMY=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_STARTER=
RAZORPAY_PLAN_ID_PRO=
RAZORPAY_PLAN_ID_ENTERPRISE=

# ---------------------------------------------------
# --- DEV --- (active when set-env-mode.sh dev)
# Use http://localhost:3100 for local; or change to https://vaniai.ngrok.app when using ngrok
# --- DEV ---
NEXT_PUBLIC_APP_URL=http://localhost:3100
EMAIL_FROM=noreply@localhost

# --- PROD ---
#NEXT_PUBLIC_APP_URL=https://vaniai.theaicompany.co
#EMAIL_FROM=noreply@vaniai.theaicompany.co
