# vaniai-app — copy to .env.local and fill in your values.
# Deployment: set-env-mode.sh (dev|prod) comments DEV block and enables PROD block (or vice versa), then generates .env for the container.
#   Dev:  http://localhost:3100 or https://vaniai.ngrok.app
#   Prod: https://vaniai.theaicompany.co

# ---------------------------------------------------
# Common (always active; not toggled by set-env-mode)
# ---------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# First value is used when comma-separated (e.g. anthropic,openai,gemini,perplexity)
LLM_PROVIDER=anthropic,openai,gemini,perplexity
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# ---------------------------------------------------
# AI models — best for each job (recommended; copy to .env.local)
# Heavy = agent loop + outreach (quality). Light = profile/monitoring (speed + cost).
# ---------------------------------------------------
# Heavy: agent loop, outreach
ANTHROPIC_MODEL=claude-opus-4-5
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro
# Light: generate profile, generate monitoring
ANTHROPIC_MODEL_LIGHT=claude-3-5-haiku-20241022
OPENAI_MODEL_LIGHT=gpt-4o-mini
GEMINI_MODEL_LIGHT=gemini-1.5-flash
# Web search (signals, research)
PERPLEXITY_MODEL=sonar
# Embeddings (knowledge base)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

RESEND_API_KEY=

# Usage limits:
# - BYPASS_USAGE_LIMITS=true: skip limits for ALL orgs (demos/testing only)
# - CREATOR_ORG_SLUG: identifiers (comma-separated) — matches org name, slug base, full slug, or website domain
#   Examples: The AI Company, the-ai-company, theaicompany, the-ai-company-1772431426010
# BYPASS_USAGE_LIMITS=true
# CREATOR_ORG_SLUG=theaicompany,theaicompany.co,onlynereputation,onlynereputation.com

RAZORPAY_DUMMY=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_STARTER=
RAZORPAY_PLAN_ID_PRO=
RAZORPAY_PLAN_ID_ENTERPRISE=

# ---------------------------------------------------
# --- DEV --- (active when set-env-mode.sh dev)
# Use http://localhost:3100 for local; or change to https://vaniai.ngrok.app when using ngrok
# NEXT_PUBLIC_APP_URL is also used for flyer/broadcast invite link default.
# --- DEV ---
NEXT_PUBLIC_APP_URL=http://localhost:3100
EMAIL_FROM=noreply@localhost
DEBUG=true
LOG_LEVEL=debug

# --- PROD ---
#NEXT_PUBLIC_APP_URL=https://vaniai.theaicompany.co
#EMAIL_FROM=noreply@vaniai.theaicompany.co
# Production: reduce log verbosity (only important stuff)
#DEBUG=false
#LOG_LEVEL=info

